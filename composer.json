{
    "name": "aiarmada/filament-shipping",
    "description": "Filament admin panel integration for aiarmada/shipping",
    "license": "MIT",
    "homepage": "https://github.com/aiarmada/commerce",
    "support": {
        "issues": "https://github.com/aiarmada/commerce/issues",
        "source": "https://github.com/aiarmada/commerce"
    },
    "require": {
        "aiarmada/shipping": "self.version",
        "filament/filament": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "AIArmada\\FilamentShipping\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AIArmada\\FilamentShipping\\FilamentShippingServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}